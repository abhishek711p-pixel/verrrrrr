generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?   
  image         String?
  role          Role      @default(STUDENT)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teacherProfile TeacherProfile?
  studentProfile StudentProfile?
  posts   CommunityPost[]
  comments Comment[]
}

model TeacherProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  subscriptionFee Float    @default(500.0) 
  
  courses         Course[]
  liveClasses     LiveClass[]
  batches         Batch[]
  sentMessages    TeacherMessage[]
  subscriptions   Subscription[]
}

model StudentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trialStartsAt   DateTime @default(now()) 
  
  subscriptions   Subscription[]
  testScores      TestScore[]
  batches         BatchStudent[]
  attendance      Attendance[]
}

model Course {
  id               String   @id @default(cuid())
  title            String
  description      String?
  teacherId        String
  teacher          TeacherProfile @relation(fields: [teacherId], references: [id])
  videos           Video[]
  createdAt        DateTime @default(now())
}

model Video {
  id            String   @id @default(cuid())
  title         String
  url           String   
  thumbnailUrl  String?
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  views         Int      @default(0)
  createdAt     DateTime @default(now())
}

model Subscription {
  id               String   @id @default(cuid())
  studentId        String
  student          StudentProfile @relation(fields: [studentId], references: [id])
  teacherId        String   
  teacher          TeacherProfile @relation(fields: [teacherId], references: [id])
  status           String   
  startDate        DateTime @default(now())
  endDate          DateTime
}

model LiveClass {
  id               String   @id @default(cuid())
  title            String
  meetingLink      String
  scheduledAt      DateTime
  teacherId        String
  teacher          TeacherProfile @relation(fields: [teacherId], references: [id])
}

model CommunityPost {
  id           String    @id @default(cuid())
  content      String
  imageUrl     String?
  authorId     String
  author       User      @relation(fields: [authorId], references: [id])
  comments     Comment[]
  scheduledFor DateTime?
  createdAt    DateTime  @default(now())
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  postId      String
  post        CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
}

model TestScore {
  id          String   @id @default(cuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  testName    String
  score       Int
  totalMarks  Int
  takenAt     DateTime @default(now())
}

model Batch {
  id          String   @id @default(cuid())
  name        String
  description String?
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  students    BatchStudent[]
  assignments Assignment[]
  attendance  Attendance[]
  messages    TeacherMessage[]
  createdAt   DateTime @default(now())
}

model BatchStudent {
  id          String   @id @default(cuid())
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  joinedAt    DateTime @default(now())

  @@unique([batchId, studentId])
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String?  
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  dueDate     DateTime?
  createdAt   DateTime @default(now())
}

model Attendance {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  status      String   // "PRESENT", "ABSENT", "LATE"
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([batchId, studentId, date])
}

model TeacherMessage {
  id          String   @id @default(cuid())
  subject     String
  content     String
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  batchId     String?  // Optional: If null, sent to all students of the teacher. If set, sent to specific batch.
  batch       Batch?   @relation(fields: [batchId], references: [id])
  createdAt   DateTime @default(now())
}
